# OpenAI (varsayılan LLM). CrewAI 1.x: "gpt-4o-mini" veya tam id "openai/gpt-4o-mini"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# İsteğe bağlı: Groq. Örnek: llama-3.3-70b-versatile veya groq/llama-3.3-70b-versatile
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# CrewAI memory embedding hatası alırsanız geçici olarak: 1
# SECURECODE_DISABLE_MEMORY=
